# ===== Required =====
DATABASE_URL="postgresql://aiverse:aiverse@localhost:5432/aiverse"
DATABASE_POOL_URL="postgresql://aiverse:aiverse@pgbouncer:6432/aiverse"
AUTH_SECRET="change-me-to-a-random-64-char-string"

# ===== Redis =====
REDIS_URL="redis://:aiverse@localhost:6379"

# ===== AI Providers (at least one required) =====
OPENROUTER_API_KEY=""
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""
GROQ_API_KEY=""
COHERE_API_KEY=""

# ===== AI Gateway Service =====
AI_GATEWAY_URL="http://ai-gateway:4001"

# ===== AI Model Overrides (optional) =====
GEMINI_MODEL="gemini-2.5-flash"
OPENROUTER_MODEL="meta-llama/llama-4-maverick:free"
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_MODEL="claude-3-haiku-20240307"
DEEPSEEK_MODEL="deepseek-chat"
GROQ_MODEL="llama-3.3-70b-versatile"
COHERE_MODEL="command-r-plus"

# ===== Email (Resend) =====
RESEND_API_KEY=""
EMAIL_FROM="noreply@aiverse.ai"

# ===== Payment Providers =====
STRIPE_SECRET=""
STRIPE_WEBHOOK_SECRET=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ===== S3-compatible Storage =====
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="aiverse"
S3_PUBLIC_URL="http://localhost:9000"

# ===== Auth =====
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ===== Captcha (Cloudflare Turnstile) =====
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY=""

# ===== Observability =====
SENTRY_DSN=""
LOG_LEVEL="debug"
OTEL_ENABLED="false"
OTEL_EXPORTER_OTLP_ENDPOINT="http://otel-collector:4318"

# ===== OpenAPI Docs =====
OPENAPI_ENABLED="true"

# ===== App =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ===== WebSocket =====
WS_PORT="3001"
