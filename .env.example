# Database
DATABASE_URL="postgresql://aiverse:aiverse@localhost:5432/aiverse?schema=public"
DIRECT_URL="postgresql://aiverse:aiverse@localhost:5432/aiverse"

# Redis
REDIS_URL="redis://:aiverse@localhost:6379"

# Auth
AUTH_SECRET="replace-with-a-strong-64-char-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# AI Providers
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
OPENROUTER_MODEL="meta-llama/llama-4-maverick:free"

# Email
RESEND_API_KEY=""

# Payments - Stripe
STRIPE_SECRET=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_CREATOR_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""
STRIPE_CONNECT_CLIENT_ID=""

# Payments - Razorpay (optional, for non-Stripe regions)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# File Storage (S3-compatible - MinIO, AWS S3, Cloudflare R2, etc.)
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="aiverse"
S3_PUBLIC_URL=""

# Error Tracking
SENTRY_DSN=""

# Cloudflare Turnstile (CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Environment
NODE_ENV="development"
LOG_LEVEL="info"
